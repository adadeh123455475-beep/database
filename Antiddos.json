cat << 'EOF' > /root/index.js
const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');
const https = require('https');

// ================= KONFIGURASI =================
const PANEL_URL = 'https://panelegalpuki.miunnst.site';
const API_KEY = 'ptla_buQ6x1OeEN3zl6yHyiINghZLvDPtSa0mHMwInGv4t7J'; // GANTI DENGAN API KEY ASLI
const BOT_TOKEN = '8661317645:AAHO7FF3bQQaG42pPee-Zx6DD0xFB9gcFkE';
const CHAT_ID = '-1003747215386';

const VOLUMES_PATH = '/var/lib/pterodactyl/volumes';
const LIMIT_GB = 5;          
const CHECK_INTERVAL = 10000; 
// ===============================================

let punished = new Set(); 

function log(msg) {
    const time = new Date().toLocaleTimeString('id-ID', { hour12: false });
    console.log(`[${time}] ${msg}`);
}

// GANTI FUNGSI TELEGRAM LU DENGAN INI:
function telegram(msg) {
    const data = JSON.stringify({ 
        chat_id: CHAT_ID, 
        text: msg, 
        parse_mode: 'HTML' 
    });
    
    const req = https.request({
        hostname: 'api.telegram.org',
        path: `/bot${BOT_TOKEN}/sendMessage`,
        method: 'POST',
        headers: { 
            'Content-Type': 'application/json', 
            // FIX UTAMA: Pakai Buffer.byteLength biar emoji & font keren terbaca akurat
            'Content-Length': Buffer.byteLength(data) 
        }
    });

    // Biar gak bisu! Kalau ada error dari Telegram, bakal muncul di Console
    req.on('response', (res) => {
        let resData = '';
        res.on('data', chunk => resData += chunk);
        res.on('end', () => {
            if (res.statusCode !== 200) {
                log(`[!] API Telegram Error: ${resData}`);
            }
        });
    });

    req.on('error', (e) => log(`[!] Network Error: ${e.message}`)); 
    req.write(data);
    req.end();
}

function apiSuspend(id) {
    try {
        const url = new URL(`${PANEL_URL}/api/application/servers/${id}/suspend`);
        const req = https.request({
            hostname: url.hostname,
            path: url.pathname,
            method: 'POST',
            headers: {
                Authorization: `Bearer ${API_KEY}`,
                Accept: 'Application/vnd.pterodactyl.v1+json',
                'Content-Type': 'application/json'
            }
        });
        req.on('error', () => {});
        req.write(JSON.stringify({}));
        req.end();
    } catch (e) {
        log(`[!] API Error: ${e.message}`);
    }
}

function getSizeGB(folder) {
    try {
        const out = execSync(`du -sb "${folder}" | cut -f1`, { timeout: 2000 }).toString();
        return parseInt(out.trim()) / 1024 / 1024 / 1024; 
    } catch (e) {
        return 0;
    }
}

function executeJudgment(id, size) {
    if (punished.has(id)) return;
    punished.add(id);

    const folder = path.join(VOLUMES_PATH, id);
    log(`[☠️] JUDGMENT PROTOCOL INITIATED FOR: ${id}`);
    
    // NOTIFIKASI AWAL (WARNING)
    telegram(`
<blockquote>𝐖𝐚𝐫𝐧𝐢𝐧𝐠 𝐒𝐩𝐢𝐤𝐞/𝐊𝐢𝐥𝐥 𝐃𝐞𝐭𝐞𝐜𝐭𝐞𝐝⚠️
⊛ 𝐒𝐫𝐯 𝐈𝐝 : ${id}
⊛ 𝐓𝐨𝐭𝐚𝐥𝐬 : ${size.toFixed(2)} GB / ${LIMIT_GB} GB
⊛ 𝐀𝐜𝐭𝐢𝐨𝐧 : sᴘɪᴋᴇ/ᴋɪʟʟ ᴘᴀɴᴇʟ🤡
⊛ 𝐍𝐨𝐭𝐞 : ᴏᴛᴡ ʜᴀᴘᴜs😹...</blockquote>
    `);

    try {
        log(` ├─ [1/3] Killing Docker Container...`);
        try { execSync(`docker kill ${id}`, { stdio: 'ignore' }); } catch {}

        log(` ├─ [2/3] Suspending Server via API...`);
        apiSuspend(id);

        log(` ├─ [3/3] Wiping Data: rm -rf ${folder}...`);
        execSync(`rm -rf "${folder}"`);
        
        execSync(`mkdir -p "${folder}"`);
        execSync(`chown 999:999 "${folder}"`); 

        log(`[√] EXECUTION COMPLETE. SERVER WIPED.`);
        
        // NOTIFIKASI SUKSES (EXECUTION DONE)
        telegram(`
<blockquote>𝐒𝐮𝐜𝐜𝐞𝐬𝐬 𝐃𝐞𝐥𝐞𝐭𝐞 𝐒𝐩𝐢𝐤𝐞𝐫/𝐊𝐢𝐥𝐥𝐞𝐫✅
⊛ 𝐒𝐫𝐯 𝐈𝐝 : ${id}
⊛ 𝐃𝐚𝐭𝐚 𝐖𝐢𝐩𝐞 : 100% Wiped (rm -rf)
⊛ 𝐀𝐜𝐭𝐢𝐨𝐧 : sᴜsᴘᴇɴᴅᴇᴅ & ʟᴏᴄᴋᴇᴅ
⊛ 𝐓𝐨𝐭𝐚𝐥𝐬 : 0.00 GB
⊛ 𝐍𝐨𝐭𝐞 : ᴋᴀsɪᴀɴ sᴄ ɴʏᴀ ᴀᴍᴘᴀs🥺😹</blockquote>
        `);

    } catch (err) {
        log(`[X] EXECUTION FAILED: ${err.message}`);
        // NOTIFIKASI GAGAL
        telegram(`
<blockquote>𝐊𝐞𝐬𝐚𝐥𝐚𝐡𝐚𝐧 𝐀𝐝𝐚 𝐘𝐠 𝐄𝐫𝐫𝐨𝐫❗
⊛ 𝐒𝐫𝐯 𝐈𝐝 : ${id}
⊛ 𝐄𝐫𝐫𝐨𝐫 𝐋𝐨𝐠 : ${err.message}
⊛ 𝐍𝐨𝐭𝐞 : ɢᴀɢᴀʟ ᴍᴇɴɢʜᴀᴘᴜs ᴛᴀʀɢᴇᴛ. ʜᴀʀᴀᴘ ᴄᴇᴋ ᴍᴀɴᴜᴀʟ ᴅɪ ᴛᴇʀᴍɪɴᴀʟ</blockquote>
        `);
    }
}

function scanServers() {
    if (!fs.existsSync(VOLUMES_PATH)) return;

    const servers = fs.readdirSync(VOLUMES_PATH);
    
    for (const id of servers) {
        const folder = path.join(VOLUMES_PATH, id);
        
        if (!fs.existsSync(folder) || id.startsWith('.')) continue;

        const size = getSizeGB(folder);

        if (size >= LIMIT_GB) {
            executeJudgment(id, size);
        } else if (punished.has(id) && size < (LIMIT_GB - 1)) {
            punished.delete(id);
        }
    }
}

console.clear();
console.log("\x1b[31m%s\x1b[0m", `
    ██╗  ██╗██████╗ ███████╗██╗   ██╗
    ╚██╗██╔╝██║  ██╗██╔════╝██║   ██║
     ╚███╔╝ ██║  ██║█████╗  ██║   ██║
     ██╔██╗ ██║  ██╗██╔══╝  ╚██╗ ██╔╝
    ██╔╝ ██╗██████╔╝███████╗ ╚████╔╝ 
    ╚═╝  ╚═╝╚═════╝ ╚══════╝  ╚═══╝  
`);
console.log("\x1b[41m\x1b[37m%s\x1b[0m", " [ XDEV ULTIMATE GUARD - RICH HTML MODE ] \n");

log(`Monitoring Path : ${VOLUMES_PATH}`);
log(`Max Limit       : ${LIMIT_GB} GB`);
log(`Scan Interval   : ${CHECK_INTERVAL / 1000} Seconds`);
log(`Status          : ACTIVE.\n`);

// NOTIFIKASI BOOTING YANG KEREN
telegram(`
<blockquote>𝐀𝐧𝐭𝐢 𝐒𝐩𝐢𝐤𝐞/𝐊𝐢𝐥𝐥 𝐀𝐤𝐭𝐢𝐟✅
⊛ 𝐓𝐚𝐫𝐠𝐞𝐭 : ${PANEL_URL}
⊛ 𝐋𝐢𝐦𝐢𝐭 : ${LIMIT_GB} GB
⊛ 𝐃𝐞𝐥𝐚𝐲 : ${CHECK_INTERVAL / 1000} sᴇᴄᴏɴᴅs
⊛ 𝐍𝐨𝐭𝐞 : ᴘʀᴏᴛᴇᴄᴛ ᴛᴇʟᴀʜ ᴀᴋᴛɪғ, ᴇɴᴊᴏʏ😘</blockquote>
`);

scanServers();
setInterval(scanServers, CHECK_INTERVAL);

process.on('uncaughtException', (err) => log(`[!] System Error: ${err.message}`));
EOF

